$params = @{
    # SOURCE
    SqlInstance         = "Server.domain.COM"
    Database            = "dbname"
    Table               = "dbo.table1"

    # DESTINATION
    Destination         = "destserver.domain.COM"
    DestinationDatabase = "dbname"
    
    # OPTIONS
    Truncate            = $true   # Empties the table before copy
    AutoCreateTable     = $true   # Creates the table if it's missing
    KeepIdentity        = $true   # Copies the exact ID values from Source
}

Copy-DbaDbTableData @params
