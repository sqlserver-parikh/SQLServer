function Backup-PostgreSQLTables {
    param(
        [string]$ServerName,
        [string]$Username,
        [string]$Password,
        [string]$DatabaseName,
        [string]$TableNames,
        [string]$OutputPath = "C:\Backups",
        [string]$PgDumpPath = "C:\Program Files\pgAdmin 4\runtime\pg_dump.exe",
        [string]$Port = "5432"
    )

    $PsqlPath = Join-Path (Split-Path $PgDumpPath) "psql.exe"

    if (-not (Test-Path $OutputPath)) {
        New-Item -ItemType Directory -Force -Path $OutputPath | Out-Null
    }

    $tables = $TableNames -split ',' | ForEach-Object { $_.Trim() }
    $timestamp = Get-Date -Format 'yyyyMMdd_HHmmss'
    $env:PGPASSWORD = $Password

    foreach ($table in $tables) {
        Write-Host "[$(Get-Date -Format 'HH:mm:ss')] Checking size for $table..." -ForegroundColor Gray
        
        # IMPROVED QUERY: Uses ::regclass to handle schema names correctly
        # We wrap the table name in single quotes.
        $sizeQuery = "SELECT pg_total_relation_size('$table'::regclass);"
        $rawSizeBytes = 0
        
        try {
            # Execute psql and capture both output and potential errors
            $dbResult = & $PsqlPath -h $ServerName -p $Port -U $Username -d $DatabaseName -t -A -c "$sizeQuery" 2>&1
            
            # Check if the result is a number
            if ($dbResult -match '^\d+$') {
                $rawSizeBytes = [long]($dbResult.Trim())
            } else {
                Write-Host "   [Warning] Could not get size. Database said: $dbResult" -ForegroundColor DarkYellow
            }
        } catch {
            Write-Host "   [Error] Size query failed: $($_.Exception.Message)" -ForegroundColor Red
        }

        # Determine Monitoring Interval & Pretty Size
        $prettySize = "$([math]::Round($rawSizeBytes / 1GB, 2)) GB"
        if ($rawSizeBytes -lt 1GB) { $prettySize = "$([math]::Round($rawSizeBytes / 1MB, 2)) MB" }

        # Dynamic Interval: < 5GB = 30s, > 5GB = 120s
        if ($rawSizeBytes -gt 0 -and $rawSizeBytes -lt 5GB) {
            $monitorInterval = 30
            $intervalText = "30 seconds"
        } else {
            $monitorInterval = 120 
            $intervalText = "2 minutes"
        }

        $cleanTableName = $table -replace '\W', '_'
        $fileName = Join-Path $OutputPath "$($ServerName -replace '\W','_')_$($DatabaseName -replace '\W','_')_${cleanTableName}_${timestamp}.backup"
        
        $argList = @(
            "--file=`"$fileName`"",
            "--host=$ServerName",
            "--port=$Port",
            "--username=$Username",
            "--format=c",
            "--large-objects",
            "--verbose",
            "--table=`"$table`"",
            $DatabaseName
        )

        Write-Host "`n[$(Get-Date -Format 'HH:mm:ss')] Starting backup for: $table" -ForegroundColor Cyan
        Write-Host "   > Estimated table Size: $prettySize" -ForegroundColor Yellow
        Write-Host "   > Updating progress every $intervalText." -ForegroundColor DarkGray
        
        $processInfo = New-Object System.Diagnostics.ProcessStartInfo
        $processInfo.FileName = $PgDumpPath
        $processInfo.Arguments = $argList
        $processInfo.RedirectStandardError = $true
        $processInfo.UseShellExecute = $false
        $processInfo.CreateNoWindow = $true
        
        $process = [System.Diagnostics.Process]::Start($processInfo)
        
        while (-not $process.HasExited) {
            if (Test-Path $fileName) {
                $currentSizeMB = (Get-Item $fileName).Length / 1MB
                Write-Host "   > [$(Get-Date -Format 'HH:mm:ss')] Progress... Local File Size: $([math]::Round($currentSizeMB, 2)) MB" -ForegroundColor Gray
            }
            Start-Sleep -Seconds $monitorInterval
        }

        $stdErr = $process.StandardError.ReadToEnd()
        if ($process.ExitCode -eq 0) {
            $finalSize = (Get-Item $fileName).Length / 1MB
            Write-Host "Successfully backed up $table ($([math]::Round($finalSize, 2)) MB)" -ForegroundColor Green
        } else {
            Write-Error "pg_dump failed for $table. Error details:`n$stdErr"
        }
    }

    Remove-Item Env:\PGPASSWORD
    Write-Host "`nAll tasks completed." -ForegroundColor Green
}

# --- Usage ---
$params = @{
    ServerName      = "ServerName"
    Username        = "UserName"
    Password        = "SecretPass"
    DatabaseName    = "DBName"
    TableNames      = "public.table1, public.table2, public.table3"
    OutputPath      = "D:\backups\"
    PgDumpPath      = "C:\Program Files\pgAdmin 4\runtime\pg_dump.exe"
}

Backup-PostgreSQLTables @params
