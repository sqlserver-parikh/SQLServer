<#
.SYNOPSIS
    Interactive GUI-based tool to search and retrieve Azure Key Vault Secrets.

.DESCRIPTION
    This script provides a graphical interface to search for secrets by name, content-type, or tags
    across one or many Azure Key Vaults. It supports targeted searching (via parameters) or 
    broad discovery (searching the entire account context).

.PARAMETER SearchTerm
    Optional search string. If omitted, a GUI popup will ask for the input.

.PARAMETER ResourceGroupName
    The specific Azure Resource Group to search. If omitted, searches all vaults in the subscription.

.PARAMETER SubscriptionId
    The specific Azure Subscription to target. If omitted, uses the current active context.

.EXAMPLE
    .\Search-AzSecrets.ps1 -ResourceGroupName "it-prod-rg"
#>

[CmdletBinding()]
param (
    [Parameter(Mandatory=$false)] [string]$SearchTerm,
    [Parameter(Mandatory=$false)] [string]$ResourceGroupName,
    [Parameter(Mandatory=$false)] [string]$SubscriptionId
)

# --- INTERNAL HELPER: GUI POPUP ---
function Show-InputPopup {
    param([string]$Title = "Azure Secret Search", [string]$Prompt = "Enter secret name or keyword:")
    Add-Type -AssemblyName System.Windows.Forms
    Add-Type -AssemblyName System.Drawing
    
    $form = New-Object System.Windows.Forms.Form
    $form.Text = $Title
    $form.Size = New-Object System.Drawing.Size(420,180)
    $form.StartPosition = "CenterScreen"
    $form.FormBorderStyle = "FixedDialog"
    $form.Topmost = $true

    $label = New-Object System.Windows.Forms.Label
    $label.Location = New-Object System.Drawing.Point(20,20); $label.Size = New-Object System.Drawing.Size(360,20)
    $label.Text = $Prompt
    $form.Controls.Add($label)

    $textBox = New-Object System.Windows.Forms.TextBox
    $textBox.Location = New-Object System.Drawing.Point(20,50); $textBox.Size = New-Object System.Drawing.Size(360,20)
    $form.Controls.Add($textBox)

    $btn = New-Object System.Windows.Forms.Button
    $btn.Location = New-Object System.Drawing.Point(305,90); $btn.Size = New-Object System.Drawing.Size(75,28)
    $btn.Text = "Search"; $btn.DialogResult = [System.Windows.Forms.DialogResult]::OK
    $form.AcceptButton = $btn; $form.Controls.Add($btn)

    $form.Add_Shown({$textBox.Focus()})
    return if ($form.ShowDialog() -eq [System.Windows.Forms.DialogResult]::OK) { $textBox.Text } else { $null }
}

# --- MAIN EXECUTION ---
process {
    try {
        Clear-Host
        Write-Host "--- Azure Secret Hunter Tool ---" -ForegroundColor Cyan

        # 1. Handle Search Term Input
        if ([string]::IsNullOrWhiteSpace($SearchTerm)) {
            $SearchTerm = Show-InputPopup
            if ([string]::IsNullOrWhiteSpace($SearchTerm)) { Write-Warning "No search term entered. Exiting."; return }
        }
        $pattern = "*$SearchTerm*"

        # 2. Azure Connection Check
        Write-Host "Checking Azure Session..." -NoNewline
        $azContext = Get-AzContext
        if (-not $azContext) {
            Write-Host " Not Connected. Please login." -ForegroundColor Yellow
            Connect-AzAccount | Out-Null
        } else { Write-Host " Connected as [$($azContext.Account)]" -ForegroundColor Green }

        # 3. Set Subscription Context if provided
        if ($SubscriptionId) {
            Write-Host "Switching to Subscription: $SubscriptionId"
            Set-AzContext -SubscriptionId $SubscriptionId | Out-Null
        }

        # 4. Discover Key Vaults
        Write-Host "Discovering Key Vaults..." -NoNewline
        if ($ResourceGroupName) {
            $vaults = Get-AzKeyVault -ResourceGroupName $ResourceGroupName -ErrorAction SilentlyContinue
        } else {
            $vaults = Get-AzKeyVault -ErrorAction SilentlyContinue
        }

        if (-not $vaults) { throw "No Key Vaults found in the current scope." }
        Write-Host " Found $($vaults.Count) vaults." -ForegroundColor Green

        # 5. Search for Secrets
        Write-Host "Searching for '$SearchTerm'..." -ForegroundColor Yellow
        $results = foreach ($v in $vaults) {
            Write-Progress -Activity "Scanning Vaults" -Status "Checking: $($v.VaultName)"
            Get-AzKeyVaultSecret -VaultName $v.VaultName -ErrorAction SilentlyContinue | 
                Where-Object { ($_.Name -like $pattern) -or ($_.ContentType -like $pattern) }
        }

        if (-not $results) { 
            Write-Host "No matches found for '$SearchTerm'." -ForegroundColor Red
            return 
        }

        # 6. Interactive Selection GUI
        $Selected = $results | Select-Object VaultName, Name, ContentType, Enabled, Updated | 
                    Out-GridView -Title "SELECT SECRETS TO REVEAL (Hold Ctrl to select multiple)" -PassThru

        if ($null -eq $Selected) { Write-Host "Selection cancelled."; return }

        # 7. Reveal Decrypted Values
        Write-Host "`nREVEALED SECRETS:" -ForegroundColor Cyan
        Write-Host "--------------------------------------------------------"
        foreach ($item in $Selected) {
            try {
                $val = Get-AzKeyVaultSecret -VaultName $item.VaultName -Name $item.Name -AsPlainText
                Write-Host "Vault:    $($item.VaultName)"
                Write-Host "Secret:   $($item.Name)"
                Write-Host "Value:    " -NoNewline; Write-Host $val -BackgroundColor Yellow -ForegroundColor Black
                Write-Host "--------------------------------------------------------"
            } catch {
                Write-Host "Error retrieving $($item.Name): $($_.Exception.Message)" -ForegroundColor Red
            }
        }
    }
    catch {
        Write-Error "FATAL ERROR: $($_.Exception.Message)"
    }
}
